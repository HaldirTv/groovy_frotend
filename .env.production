# Groovra Frontend — Production Environment Variables (Vercel)

# Backend API Gateway URL on Azure
VITE_GATEWAY_URL=https://groovra-api-gateway.azurewebsites.net

# Google OAuth 2.0 Client ID
# Set your production Google Client ID from Google Cloud Console
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
